{
  "name": "nlpp-grammar",
  "version": "1.0.0",
  "description": "Parser for the Natural Language++ pseudo-code spec for AI agents",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stur86/nlpp-grammar.git"
  },
  "license": "MIT",
  "author": {
    "name": "Simone Sturniolo",
    "email": "simonesturniolo@gmail.com"
  },
  "main": "bindings/node",
  "types": "bindings/node",
  "exports": {
    ".": {
      "browser": "./bindings/node/browser-stub.js",
      "default": "./bindings/node/index.js"
    },
    "./wasm": "./tree-sitter-nlpp.wasm",
    "./queries/highlights": "./queries/highlights.scm"
  },
  "keywords": [
    "incremental",
    "parsing",
    "tree-sitter",
    "nlpp"
  ],
  "files": [
    "grammar.js",
    "tree-sitter.json",
    "bindings/node/browser-stub.js",
    "bindings/node/index.js",
    "bindings/node/index.d.ts",
    "queries/*",
    "src/grammar.json",
    "src/node-types.json",
    "src/parser.c",
    "src/tree_sitter/**",
    "*.wasm"
  ],
  "devDependencies": {
    "tree-sitter-cli": "^0.26.8"
  },
  "scripts": {
    "build": "tree-sitter generate && tree-sitter build --wasm",
    "prepublishOnly": "tree-sitter generate && tree-sitter build --wasm",
    "prestart": "tree-sitter generate && tree-sitter build --wasm",
    "start": "tree-sitter playground",
    "test": "tree-sitter test"
  }
}
