{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "nlpp",
      "camelcase": "NLpp",
      "title": "NL++",
      "scope": "source.nlpp",
      "file-types": [
        "nlpp"
      ],
      "injection-regex": "^nlpp$",
      "class-name": "TreeSitterNlpp"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "Parser for the Natural Language++ pseudo-code spec for AI agents",
    "authors": [
      {
        "name": "Simone Sturniolo",
        "email": "simonesturniolo@gmail.com",
        "url": ""
      }
    ],
    "links": {
      "repository": "https://github.com/stur86/nlpp-grammar",
      "funding": ""
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "java": false,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true,
    "zig": false
  }
}