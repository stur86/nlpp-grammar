* text=auto eol=lf

# Generated source files
src/*.json linguist-generated
src/parser.c linguist-generated
src/tree_sitter/* linguist-generated

# The compiled grammar. Committed only for as long as consumers install via git
# refs rather than npm — see CONTRIBUTING.md.
*.wasm binary linguist-generated

# The Node entry point is hand-written (it locates the WASM; it is not a
# generated binding), so it is deliberately not marked linguist-generated.
package.json linguist-generated
package-lock.json linguist-generated
